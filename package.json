{
  "name": "sill",
  "productName": "Sill",
  "version": "0.1.1",
  "private": true,
  "description": "Sill — Obsidian notes, on your desktop.",
  "author": "stefan@friday430.io",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron .\"",
    "build": "vite build && electron-builder --win nsis --publish never",
    "build:win": "vite build && electron-builder --win nsis --publish never",
    "build:mac": "vite build && electron-builder --mac --publish never",
    "vite": "vite",
    "start": "electron ."
  },
  "dependencies": {
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "io.friday430.sill",
    "productName": "Sill",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "build/icon.ico"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Sill",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
